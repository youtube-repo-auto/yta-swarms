# ─────────────────────────────────────────────
# YouTube Automation Pipeline – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://tcpkymjnsewdbojrjzcu.supabase.co
# Use the service_role key (has full table access, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Anthropic (Claude) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Search (choose one) ───────────────────────
# SerpAPI gives high-quality Google results (paid, ~$50/month for 5k queries)
SERPAPI_KEY=                        # Leave empty to use DuckDuckGo fallback

# ── Pipeline Settings ─────────────────────────
# Niche / channel description used by the Content Planning Agent
CHANNEL_NICHE=Real Estate NL – vastgoedinvesteringen voor Nederlandse investeerders 25-45 jaar

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
